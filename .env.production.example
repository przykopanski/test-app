# ============================================================
# Production environment variables for docker-compose.yml
# Copy to .env and fill in real values (NEVER commit .env)
# ============================================================

# PostgreSQL
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE=ticketsystem

# JWT Secret – generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_STRING
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Cookie: set to true once HTTPS is active via Nginx Proxy Manager
COOKIE_SECURE=true

# Frontend URL (as configured in Nginx Proxy Manager, no trailing slash)
CORS_ORIGIN=http://your-server-ip-or-domain

# Backend API URL visible to the browser
# If Nginx Proxy routes /api → backend:3001, use the same domain
# Otherwise expose port 3001 directly
NEXT_PUBLIC_API_URL=http://your-server-ip-or-domain:3001/api
