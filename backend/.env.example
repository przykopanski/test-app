# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me-in-production
DB_DATABASE=ticketsystem

# JWT – generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# App
PORT=3001
# IMPORTANT: Set to false in production – use database migrations instead
DB_SYNCHRONIZE=false
# Production: Set to true once HTTPS is terminated by Nginx Proxy Manager
COOKIE_SECURE=false
# Frontend URL for CORS (no trailing slash)
CORS_ORIGIN=http://localhost:3000
